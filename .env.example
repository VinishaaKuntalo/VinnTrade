# Public site URL (canonical links, sitemap, Open Graph). On Vercel, also set
# this to your production domain (VERCEL_URL is a fallback in code).
NEXT_PUBLIC_SITE_URL=https://example.com

# Market data (server-only; never commit real keys)
FINNHUB_API_KEY=

# /api rate limiting (middleware)
# API_RATE_LIMIT_MAX=120
# API_RATE_WINDOW_MS=60000

# Comma-separated browser origins allowed to call /api cross-origin. Leave
# empty for same-origin only.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Broker integrations (see src/app/api/broker/)
# SNAPTRADE_CLIENT_ID=
# SNAPTRADE_CONSUMER_KEY=
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# IBKR_GATEWAY_URL=

# ── Near-real-time data (optional tuning) ──────────────────────
# Server in-memory TTL for OHLCV routes (ms). Lower = fresher daily bars, more provider calls.
# VINNTRADE_CHART_CACHE_MS=90000
# VINNTRADE_SIGNAL_CACHE_MS=45000
# Single-symbol quote route TTL (ms); batch /api/quotes stays ~15s.
# VINNTRADE_QUOTE_CACHE_MS=60000

# Browser poll intervals (ms). Set at build time (NEXT_PUBLIC_*).
# NEXT_PUBLIC_CHART_REFRESH_MS=90000
# NEXT_PUBLIC_SIGNAL_REFRESH_MS=90000
# Chart-page insight strip only (falls back to NEXT_PUBLIC_SIGNAL_REFRESH_MS).
# NEXT_PUBLIC_SIGNAL_INSIGHT_REFRESH_MS=45000