# Public site URL (canonical links, sitemap, Open Graph). On Vercel, also set
# this to your production domain (VERCEL_URL is a fallback in code).
NEXT_PUBLIC_SITE_URL=https://example.com

# Market data (server-only; never commit real keys)
FINNHUB_API_KEY=

# /api rate limiting (middleware)
# API_RATE_LIMIT_MAX=120
# API_RATE_WINDOW_MS=60000

# Comma-separated browser origins allowed to call /api cross-origin. Leave
# empty for same-origin only.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Broker integrations (see src/app/api/broker/)
# SNAPTRADE_CLIENT_ID=
# SNAPTRADE_CONSUMER_KEY=
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# IBKR_GATEWAY_URL=
